//.vscode\launch.json
{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Run TomoCoffee",
      "request": "launch",
      "mainClass": "main.Main",
      "classPaths": [
        "${workspaceFolder}/build/classes",
        "${workspaceFolder}/library/mysql-connector-j-9.1.0.jar",
        "${workspaceFolder}/library/gson-2.10.1.jar",
        "${workspaceFolder}/library/fontawesomefx-8.2.jar"
      ],
      "vmArgs": "--module-path \"${workspaceFolder}\\javafx-sdk-21.0.11\\lib\" --add-modules javafx.controls,javafx.fxml,javafx.graphics,javafx.media,javafx.web --enable-native-access=javafx.graphics",
      "env": {
        "PATH": "${workspaceFolder}\\javafx-sdk-21.0.11\\bin;${env:PATH}"
      }
    }
  ]
}